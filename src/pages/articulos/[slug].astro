---
import { getCollection, render } from 'astro:content';
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import AdInArticle from '../../components/ads/AdInArticle.astro';

export async function getStaticPaths() {
  const articulos = await getCollection('articulos', ({ data }) => !data.draft);
  return articulos.map((articulo) => ({
    params: { slug: articulo.id },
    props: { articulo },
  }));
}

const { articulo } = Astro.props;
const { Content, headings } = await render(articulo);
---

<ArticleLayout
  articulo={articulo}
  headings={headings}
  rawContent={articulo.body ?? ''}
>
  <Content />

  {/* Opt-in de anuncios in-article (máx. 3 por página vía prop `index`). */}
  <AdInArticle slotId="9999999990" index={0} slot="ad-after-intro" />
  <AdInArticle slotId="9999999991" index={1} slot="ad-mid" />
  <AdInArticle slotId="9999999992" index={2} slot="ad-before-faq" />
</ArticleLayout>
