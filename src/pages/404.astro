---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/content/ArticleCard.astro';

// Sugerir artículos destacados (o los más recientes como fallback).
const todos = await getCollection('articulos', ({ data }) => !data.draft);
const destacados = (todos.filter((a) => a.data.featured).length ? todos.filter((a) => a.data.featured) : todos)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);

const sugerencias = await Promise.all(
  destacados.map(async (a) => {
    const cat = await getEntry(a.data.categoria);
    return {
      href: `/articulos/${a.id}`,
      title: a.data.title,
      description: a.data.description,
      categoria: cat?.data.nombre,
      pubDate: a.data.pubDate,
    };
  }),
);
---

<BaseLayout title="Página no encontrada" description="La página que buscas no existe." noindex>
  <section class="mx-auto max-w-3xl px-4 py-20 text-center">
    <p class="text-6xl font-extrabold text-brand">404</p>
    <h1 class="mt-4 text-3xl font-bold text-ink">Página no encontrada</h1>
    <p class="mt-3 text-muted">
      La página que buscas no existe o se ha movido. Prueba con uno de estos artículos
      o vuelve al inicio.
    </p>
    <a
      href="/"
      class="mt-6 inline-block rounded-lg bg-brand px-5 py-3 font-semibold text-white hover:bg-brand-dark transition-colors"
    >
      Volver al inicio
    </a>
  </section>

  {
    sugerencias.length > 0 && (
      <section class="mx-auto max-w-6xl px-4 pb-16">
        <h2 class="text-xl font-bold text-ink mb-5">Artículos populares</h2>
        <div class="grid gap-6 sm:grid-cols-3">
          {sugerencias.map((a) => (
            <ArticleCard
              href={a.href}
              title={a.title}
              description={a.description}
              categoria={a.categoria}
              pubDate={a.pubDate}
            />
          ))}
        </div>
      </section>
    )
  }
</BaseLayout>
