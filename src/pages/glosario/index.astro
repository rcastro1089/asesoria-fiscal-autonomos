---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/layout/Breadcrumbs.astro';
import type { BreadcrumbItem } from '../../lib/schema';
import glosario from '../../data/glosario.json';

interface TerminoGlosario {
  termino: string;
  slug: string;
  definicion: string;
  definicionAmpliada: string;
  categoria: string;
  relacionados: string[];
}

const title = 'Glosario Fiscal para Autónomos - Definiciones y Términos';
const description =
  'Diccionario fiscal completo para autónomos en España. Más de 100 términos explicados: IRPF, IVA, retenciones, modelos, cotización y más.';

const breadcrumbs: BreadcrumbItem[] = [
  { name: 'Glosario', url: '/glosario' },
];

// --- Normalización de letras (sin acentos, mayúscula, NFD) ---
function normalizeLetter(input: string): string {
  const decomposed = input.normalize('NFD').replace(/[\u0300-\u036f]/g, '');
  return decomposed.toUpperCase();
}

// --- Validación de unicidad de slugs (Set) ---
// El JSON incluye un slug duplicado (modelo-036). Conservamos la primera
// aparición para que getStaticPaths y los enlaces relacionados no se rompan.
const seenSlugs = new Set<string>();
const uniqueTerms: TerminoGlosario[] = [];
let duplicateSlugs = 0;
for (const item of glosario as TerminoGlosario[]) {
  if (seenSlugs.has(item.slug)) {
    duplicateSlugs += 1;
    continue;
  }
  seenSlugs.add(item.slug);
  uniqueTerms.push(item);
}

// --- Agrupación por inicial ---
type LetterGroup = { letter: string; terms: TerminoGlosario[] };
const groupsMap = new Map<string, TerminoGlosario[]>();

for (const term of uniqueTerms) {
  const firstChar = normalizeLetter(term.termino.charAt(0));
  // Si no es letra A-Z (p. ej. número o símbolo), agrupamos en '#'.
  const letter = /^[A-Z]$/.test(firstChar) ? firstChar : '#';
  if (!groupsMap.has(letter)) groupsMap.set(letter, []);
  groupsMap.get(letter)!.push(term);
}

// Ordenamos términos dentro de cada letra (alfabético, insensible a acentos).
for (const list of groupsMap.values()) {
  list.sort((a, b) =>
    normalizeLetter(a.termino).localeCompare(normalizeLetter(b.termino), 'es'),
  );
}

// Letras presentes ordenadas, con '#' al final.
const groupKeys = Array.from(groupsMap.keys()).sort();
if (groupKeys.includes('#')) {
  groupKeys.splice(groupKeys.indexOf('#'), 1);
  groupKeys.push('#');
}

const groups: LetterGroup[] = groupKeys.map((letter) => ({
  letter,
  terms: groupsMap.get(letter)!,
}));

// Alfabeto completo A-Z para la barra de navegación (las ausentes se marcan).
const ALPHABET = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ'.split('');

// Estilos para el badge de categoría (reutilizados).
const categoriaLabel: Record<string, string> = {
  impuestos: 'Impuestos',
  modelos: 'Modelos',
  cotizacion: 'Cotización',
  facturacion: 'Facturación',
  general: 'General',
};
---

<BaseLayout title={title} description={description}>
  <article class="mx-auto w-full max-w-5xl px-4 py-10 sm:px-6 lg:py-14">
    <Breadcrumbs items={breadcrumbs} />

    <header class="mt-6">
      <p
        class="text-sm font-semibold uppercase tracking-wider text-brand"
      >
        Diccionario fiscal
      </p>
      <h1 class="mt-2 text-3xl font-bold tracking-tight text-ink sm:text-4xl">
        Glosario Fiscal para Autónomos
      </h1>
      <p class="mt-4 max-w-3xl text-lg text-muted">
        Diccionario fiscal completo para autónomos en España. Más de 100
        términos explicados: IRPF, IVA, retenciones, modelos, cotización y más.
      </p>
    </header>

    <!-- Contenido SEO introductorio -->
    <section class="prose prose-slate mt-8 max-w-none">
      <p>
        El glosario fiscal para autónomos reúne, en un único diccionario en
        línea, todas las definiciones que necesitas para entender tu
        contabilidad y tus obligaciones frente a la Agencia Tributaria. Hemos
        compilado más de un centenar de términos clave del mundo fiscal español
        —desde conceptos básicos como <strong>factura</strong>,
        <strong>IVA</strong> o <strong>IRPF</strong> hasta otros más técnicos
        como <strong>estimación directa</strong>, <strong>retención</strong>,
        <strong>base imponible</strong> o <strong>cuota de autónomos</strong>—
        y los hemos explicado con un lenguaje claro, sin tecnicismos
        innecesarios y siempre orientados a la realidad del trabajador por
        cuenta propia.
      </p>
      <p>
        Cada entrada incluye una definición breve para una consulta rápida y
        una explicación ampliada con ejemplos prácticos, modelos de Hacienda
        asociados y referencias cruzadas a términos relacionados. La
        navegación alfabética te permite saltar directamente a la letra que te
        interese, y el buscador filtra al instante todas las entradas que
        coinciden con tu consulta, tanto en el término como en su definición.
      </p>
      <p>
        Usa este glosario como guía de consulta mientras cumples tus
        obligaciones trimestrales —modelos 303, 130, 111 o 115—, preparas la
        campaña de la Renta o revisas tu cotización a la Seguridad Social.
        Aunque la información se revisa periódicamente, la normativa fiscal
        cambia con frecuencia: ante cualquier duda que afecte a tu declaración,
        conviene confirmar el criterio con un asesor fiscal colegiado.
      </p>
    </section>

    <!-- Buscador client-side -->
    <div class="mt-10">
      <label for="glosario-busqueda" class="sr-only">Buscar término</label>
      <div class="relative">
        <span class="pointer-events-none absolute inset-y-0 left-3 flex items-center text-muted" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M9 3.5a5.5 5.5 0 100 11 5.5 5.5 0 000-11zM2 9a7 7 0 1112.452 4.391l3.328 3.329a.75.75 0 11-1.06 1.06l-3.329-3.328A7 7 0 012 9z" clip-rule="evenodd" />
          </svg>
        </span>
        <input
          id="glosario-busqueda"
          type="search"
          autocomplete="off"
          placeholder="Busca un término (IVA, retención, modelo 130…)"
          class="block w-full rounded-lg border border-line bg-white py-3 pl-10 pr-4 text-base text-ink placeholder:text-muted focus:border-brand focus:outline-none focus:ring-2 focus:ring-brand/30"
        />
      </div>
      <p id="glosario-busqueda-estado" class="mt-2 text-sm text-muted" aria-live="polite"></p>
    </div>

    <!-- Navegación alfabética A-Z -->
    <nav aria-label="Índice alfabético" class="mt-8">
      <ul class="flex flex-wrap gap-1.5 sm:gap-2">
        {ALPHABET.map((letter) => {
          const hasGroup = groupsMap.has(letter);
          return (
            <li>
              {hasGroup ? (
                <a
                  href={`#letra-${letter}`}
                  class="flex h-9 w-9 items-center justify-center rounded-md border border-line bg-surface font-semibold text-ink transition-colors hover:border-brand hover:bg-brand hover:text-white"
                >
                  {letter}
                </a>
              ) : (
                <span
                  aria-disabled="true"
                  class="flex h-9 w-9 cursor-not-allowed items-center justify-center rounded-md border border-line bg-surface/50 font-semibold text-muted/40"
                >
                  {letter}
                </span>
              )}
            </li>
          );
        })}
      </ul>
    </nav>

    <!-- Listado por letras -->
    <div id="glosario-listado" class="mt-10 space-y-12">
      {groups.map((group) => (
        <section
          id={`letra-${group.letter}`}
          class="glosario-grupo scroll-mt-28"
          data-letra={group.letter}
        >
          <h2 class="border-b border-line pb-3 text-2xl font-bold text-brand">
            {group.letter === '#' ? '0-9 / Otros' : group.letter}
            <span class="ml-2 align-middle text-sm font-normal text-muted">
              ({group.terms.length})
            </span>
          </h2>
          <ul class="mt-4 grid grid-cols-1 gap-3 sm:grid-cols-2">
            {group.terms.map((term) => (
              <li
                class="glosario-item flex flex-col rounded-lg border border-line bg-white p-4 transition-colors hover:border-brand/60 hover:bg-surface"
                data-nombre={term.termino.toLowerCase()}
                data-definicion={term.definicion.toLowerCase()}
              >
                <a
                  href={`/glosario/${term.slug}`}
                  class="font-semibold text-ink transition-colors hover:text-brand"
                >
                  {term.termino}
                </a>
                <span class="mt-1 line-clamp-2 text-sm text-muted">
                  {term.definicion}
                </span>
                <span class="mt-2 inline-flex w-fit items-center rounded-full bg-surface px-2 py-0.5 text-xs font-medium text-muted">
                  {categoriaLabel[term.categoria] ?? term.categoria}
                </span>
              </li>
            ))}
          </ul>
        </section>
      ))}
    </div>

    <!-- Resultado vacío para el buscador -->
    <p
      id="glosario-vacio"
      class="mt-10 hidden rounded-lg border border-dashed border-line bg-surface p-6 text-center text-muted"
    >
      No se han encontrado términos que coincidan con tu búsqueda.
    </p>

    <footer class="mt-12 border-t border-line pt-6 text-sm text-muted">
      <p>
        La información de este glosario tiene carácter divulgativo y no
        constituye asesoramiento fiscal personalizado. Consulta con un asesor
        colegiado antes de tomar decisiones.
      </p>
    </footer>
  </article>

  <script>
    // --- Filtro client-side por término o definición ---
    const input = document.getElementById('glosario-busqueda') as HTMLInputElement | null;
    const estado = document.getElementById('glosario-busqueda-estado');
    const vacio = document.getElementById('glosario-vacio');
    const items = Array.from(document.querySelectorAll<HTMLLIElement>('.glosario-item'));
    const grupos = Array.from(document.querySelectorAll<HTMLElement>('.glosario-grupo'));

    if (input) {
      input.addEventListener('input', () => {
        const q = input.value.trim().toLowerCase();
        let visibles = 0;

        for (const item of items) {
          const nombre = item.dataset.nombre ?? '';
          const def = item.dataset.definicion ?? '';
          const match = q === '' || nombre.includes(q) || def.includes(q);
          item.classList.toggle('hidden', !match);
          if (match) visibles += 1;
        }

        // Oculta las secciones de letra que se queden vacías.
        let gruposVisibles = 0;
        for (const grupo of grupos) {
          const tieneVisibles = grupo.querySelectorAll('.glosario-item:not(.hidden)').length > 0;
          grupo.classList.toggle('hidden', !tieneVisibles);
          if (tieneVisibles) gruposVisibles += 1;
        }

        if (vacio) vacio.classList.toggle('hidden', visibles !== 0);
        if (estado) {
          estado.textContent =
            q === '' ? '' : visibles === 0
              ? `Sin resultados para «${q}».`
              : `${visibles} ${visibles === 1 ? 'término' : 'términos'} encontrado${visibles === 1 ? '' : 's'}.`;
        }
      });
    }
  </script>
</BaseLayout>
