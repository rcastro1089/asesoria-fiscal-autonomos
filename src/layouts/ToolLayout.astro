---
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/layout/Breadcrumbs.astro';
import { site } from '../data/site';
import type { BreadcrumbItem } from '../lib/schema';

interface Props {
  title: string;
  description: string;
  /** Migas de pan sin "Inicio". */
  breadcrumbs: BreadcrumbItem[];
}

const { title, description, breadcrumbs } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <div class="mx-auto max-w-4xl px-4 py-8">
    <Breadcrumbs items={breadcrumbs} />

    <header class="mt-6 mb-8">
      <h1 class="text-3xl sm:text-4xl font-extrabold text-ink">{title}</h1>
      <p class="mt-3 text-lg text-muted">{description}</p>
    </header>

    {/* Isla interactiva (calculadora / calendario) — Fase 4 */}
    <slot name="tool" />

    {/* Contenido SEO explicativo */}
    <div class="prose prose-slate max-w-none mt-10">
      <slot />
    </div>

    <aside
      class="mt-10 rounded-xl border border-line bg-surface p-4 text-sm text-muted"
    >
      <p>{site.disclaimer}</p>
    </aside>
  </div>
</BaseLayout>
