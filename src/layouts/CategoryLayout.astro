---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/layout/Breadcrumbs.astro';

interface Props {
  categoria: CollectionEntry<'categorias'>;
}

const { categoria } = Astro.props;
const { data } = categoria;
---

<BaseLayout title={data.nombre} description={data.descripcion}>
  <div class="mx-auto max-w-6xl px-4 py-8">
    <Breadcrumbs items={[{ name: data.nombre, url: `/categoria/${categoria.id}` }]} />

    <header class="mt-6 mb-10 max-w-3xl">
      <h1 class="text-3xl sm:text-4xl font-extrabold text-ink">{data.nombre}</h1>
      <p class="mt-3 text-lg text-muted">{data.descripcion}</p>
    </header>

    <slot />
  </div>
</BaseLayout>
