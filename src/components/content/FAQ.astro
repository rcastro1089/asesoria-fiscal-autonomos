---
interface Props {
  faq: { q: string; a: string }[];
  title?: string;
}

const { faq, title = 'Preguntas frecuentes' } = Astro.props;
---

{
  faq?.length > 0 && (
    <section aria-labelledby="faq" class="mt-12">
      <h2 id="faq" class="text-2xl font-bold text-ink mb-5">
        {title}
      </h2>
      <div class="divide-y divide-line rounded-xl border border-line">
        {faq.map((item) => (
          <details class="group p-5">
            <summary class="flex cursor-pointer list-none items-center justify-between gap-4 font-semibold text-ink">
              <span>{item.q}</span>
              <span
                aria-hidden="true"
                class="shrink-0 text-brand transition-transform group-open:rotate-45"
              >
                +
              </span>
            </summary>
            <p class="mt-3 text-muted leading-relaxed" set:html={item.a} />
          </details>
        ))}
      </div>
    </section>
  )
}
