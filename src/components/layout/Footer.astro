---
import { site } from '../../data/site';
import { categorias, legalNav } from '../../data/nav';

const year = new Date().getFullYear();
---

<footer class="mt-16 border-t border-line bg-surface">
  <div class="mx-auto max-w-6xl px-4 py-12 grid gap-10 md:grid-cols-3">
    <div>
      <div class="flex items-center gap-2 mb-3">
        <img src="/favicon.svg" alt="" width="24" height="24" class="rounded" />
        <span class="font-bold text-ink">{site.shortName}</span>
      </div>
      <p class="text-sm text-muted leading-relaxed">{site.description}</p>
    </div>

    <nav aria-label="Categorías">
      <h2 class="text-sm font-semibold text-ink mb-3">Categorías</h2>
      <ul class="space-y-2 text-sm">
        {
          categorias.map((item) => (
            <li>
              <a href={item.href} class="text-muted hover:text-brand transition-colors">
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <nav aria-label="Información legal">
      <h2 class="text-sm font-semibold text-ink mb-3">Información</h2>
      <ul class="space-y-2 text-sm">
        {
          legalNav.map((item) => (
            <li>
              <a href={item.href} class="text-muted hover:text-brand transition-colors">
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>

  <div class="border-t border-line">
    <div class="mx-auto max-w-6xl px-4 py-6 space-y-3">
      <p class="text-xs text-muted leading-relaxed">{site.disclaimer}</p>
      <p class="text-xs text-muted">
        © {year} {site.name}. Todos los derechos reservados.
      </p>
    </div>
  </div>
</footer>
