{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "nombre": {
      "type": "string"
    },
    "descripcion": {
      "type": "string"
    },
    "orden": {
      "default": 0,
      "type": "number"
    },
    "icono": {
      "type": "string"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "nombre",
    "descripcion"
  ]
}