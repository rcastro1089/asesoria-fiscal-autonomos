{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "maxLength": 60
    },
    "description": {
      "type": "string",
      "maxLength": 160
    },
    "categoria": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "type": "string"
        },
        {
          "type": "object",
          "properties": {
            "id": {
              "type": "string"
            },
            "collection": {
              "type": "string"
            }
          },
          "required": [
            "id",
            "collection"
          ]
        },
        {
          "type": "object",
          "properties": {
            "slug": {
              "type": "string"
            },
            "collection": {
              "type": "string"
            }
          },
          "required": [
            "slug",
            "collection"
          ]
        }
      ]
    },
    "autor": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "type": "string"
        },
        {
          "type": "object",
          "properties": {
            "id": {
              "type": "string"
            },
            "collection": {
              "type": "string"
            }
          },
          "required": [
            "id",
            "collection"
          ]
        },
        {
          "type": "object",
          "properties": {
            "slug": {
              "type": "string"
            },
            "collection": {
              "type": "string"
            }
          },
          "required": [
            "slug",
            "collection"
          ]
        }
      ]
    },
    "pubDate": {
      "type": "string",
      "format": "date-time"
    },
    "updatedDate": {
      "type": "string",
      "format": "date-time"
    },
    "heroImage": {
      "type": "string"
    },
    "keywords": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "cpc": {
      "type": "number"
    },
    "volumen": {
      "type": "number"
    },
    "faq": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "q": {
            "type": "string"
          },
          "a": {
            "type": "string"
          }
        },
        "required": [
          "q",
          "a"
        ]
      }
    },
    "howto": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "paso": {
            "type": "string"
          },
          "detalle": {
            "type": "string"
          }
        },
        "required": [
          "paso",
          "detalle"
        ]
      }
    },
    "draft": {
      "default": false,
      "type": "boolean"
    },
    "featured": {
      "default": false,
      "type": "boolean"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "description",
    "categoria",
    "autor",
    "pubDate"
  ]
}